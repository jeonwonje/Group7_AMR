@startuml 01-hld-architectural-overview
!pragma layout smetana
!include _style.iuml

title <b><size:24>Architectural Overview</size></b>\n<size:16>Two-machine ROS 2 Humble workspace, CycloneDDS unicast over Wi-Fi</size>

skinparam componentStyle rectangle

node "Laptop" as Laptop {
  component "Cartographer SLAM\n/map, /tf" as Cart
  component "Nav2 stack\nplanner + controller" as Nav2
  component "auto_explore_v2\nfrontiers → goals" as Explore
  component "mission_coordinator\ncentral FSM" as Coord #E8DAEF
  component "docking_server\ndocker.py" as Dock #E8DAEF
  component "search_stations\nzone sweep + 360° spin" as Search #FDEBD0
  component "RViz2\nvisualisation" as RViz #F7F7F7

  Cart -down-> Nav2
  Nav2 -down-> Explore
  Explore -down-> Coord
  Coord ..> Dock : /mission_command
  Coord ..> Search : /mission_command
}

node "Raspberry Pi 4B" as RPi {
  component "turtlebot3_bringup\nOpenCR + LDS-02" as Bringup
  component "apriltag_docking\nvision container +\ndock-pose pubs" as Apriltag
  component "delivery_server\nshot orchestration\nMG90 servo · GPIO 12" as Delivery #FADBD8
}

Laptop <-down-> RPi : <b>CycloneDDS unicast</b>\nover Wi-Fi

@enduml
